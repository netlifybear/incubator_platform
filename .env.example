# =============================================================================
# Incubator Trust Platform — Environment Variables
# =============================================================================
# Copy this to .env and fill in values.

# --- Database ---
# Local development: `npx prisma dev` prints both URLs.
# Vercel + Supabase demo:
# - DATABASE_URL should be the pooled Supabase Postgres URL used by the app runtime.
# - DIRECT_DATABASE_URL should be the direct Supabase Postgres URL used by Prisma CLI/schema/seed commands.
# - URL-encode special characters in database passwords, especially `$`, so Next's env expansion does not alter them.
DATABASE_URL="prisma+postgres://..."
DIRECT_DATABASE_URL="postgres://..."

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (for GSC integration) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add the redirect URI: {NEXTAUTH_URL}/api/auth/gsc
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (magic-link + notifications) ---
# Get an API key from https://resend.com
# In dev, emails are logged to console — no Resend key needed.
RESEND_API_KEY=""
EMAIL_FROM="noreply@incubator-trust.com"

# --- Cross-Instance Reputation Portability ---
# Shared secret for signing and verifying reputation JWTs.
# Must be the same across all incubator instances that share reputation.
# Generate with: openssl rand -base64 32
REPUTATION_SHARED_SECRET="replace-with-a-random-secret"

# --- External Badge Award Secrets ---
# Pepper used to HMAC vendor/investor award secrets before database storage/lookup.
# Generate with: openssl rand -base64 32
ISSUER_SECRET_PEPPER="replace-with-a-random-secret"

# --- Weekly Digest Cron ---
# Set a shared secret to protect the cron endpoint from unauthorized access.
# The cron endpoint is at GET /api/cron/weekly-digest?cohortId=<id>
# Generate with: openssl rand -base64 32
CRON_SECRET="replace-with-a-random-secret"
